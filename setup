#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$HOME/.claude/skills"

echo ""
echo "  cardnews-kit"
echo "  ─────────────────────────────"
echo "  Build editorial carousels with AI"
echo ""

# ── Step 1: Install skills ──────────────────────────

echo "  [1/3] Installing skills..."

mkdir -p "$SKILLS_DIR"

SKILLS=(
  "onboard"
  "benchmark"
  "design-system"
  "voice"
  "story"
  "factcheck"
  "illustrate"
  "lint"
  "render"
  "publish"
  "browse"
)

for skill in "${SKILLS[@]}"; do
  target="$SKILLS_DIR/ck-$skill"
  source="$SCRIPT_DIR/$skill"

  # Remove old symlink or dir, then copy fresh
  rm -rf "$target"
  mkdir -p "$target"
  cp "$source/SKILL.md" "$target/SKILL.md"
done

echo "        ✓ ${#SKILLS[@]} skills → ~/.claude/skills/ck-*"
echo ""

# ── Step 2: Python + Playwright ─────────────────────

echo "  [2/3] Checking Python..."

if ! command -v python3 &> /dev/null; then
    echo "        ✗ python3 not found. Install Python 3.10+ and re-run."
    exit 1
fi
echo "        ✓ python3 found"

echo ""
echo "  [3/3] Checking Playwright..."

if python3 -c "import playwright" 2>/dev/null; then
    echo "        ✓ Playwright installed"
else
    echo "        Installing Playwright..."
    pip3 install playwright
    echo "        ✓ Playwright installed"
fi

if python3 -c "
from playwright.sync_api import sync_playwright
p = sync_playwright().start()
p.chromium.executable_path
p.stop()
" 2>/dev/null; then
    echo "        ✓ Chromium ready"
else
    echo "        Installing Chromium..."
    python3 -m playwright install chromium
    echo "        ✓ Chromium ready"
fi

# ── Done ────────────────────────────────────────────

echo ""
echo "  ─────────────────────────────"
echo "  ✓ Setup complete!"
echo ""
echo "  Skills installed:"
for skill in "${SKILLS[@]}"; do
  echo "    /ck-$skill"
done
echo ""
echo "  Next: run /ck-onboard in Claude Code"
echo ""
